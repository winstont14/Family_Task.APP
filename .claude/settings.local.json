      "Read(//usr/local/**)",
      "Bash(brew install *)",
      "Bash(flutter run *)",
      "Bash(gh auth *)",
      "Bash(flutter analyze *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(lsof -iTCP -sTCP:LISTEN -n)",
      "Bash(awk '{print $9}')",
      "Bash(flutter build *)",
      "Bash(grep -v \"^  info\\\\|Downloading\\\\|newer versions\\\\|Try \\\\`flutter\\\\|Got dep\\\\|Resolving\\\\| available\")",
      "Bash(gh run *)",
      "Bash(open \"http://localhost:53874\")",
      "Bash(open -a \"Google Chrome\" \"http://localhost:53874\")",
      "Bash(pkill -f \"flutter run\")",
      "Bash(git commit *)",
